{
  "version": 2,
  "name": "fxa-vsl",
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "**/*.js",   "use": "@vercel/static" },
    { "src": "**/*.css",  "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
